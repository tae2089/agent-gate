{
  "agent-gate": {
    "PreInvocation": [
      {
        "type": "command",
        "command": "python3 \"$HOME/.gemini/antigravity-cli/plugins/agent-gate/hooks/antigravity_reinject.py\""
      }
    ],
    "PreToolUse": [
      {
        "matcher": "write_to_file",
        "hooks": [
          {
            "type": "command",
            "command": "p=\"$HOME/.gemini/antigravity-cli/plugins/agent-gate\"; python3 \"$p/hooks/antigravity_adapter.py\" --event pretooluse -- python3 \"$p/hooks/readiness_gate_hook.py\" --mode pre"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "write_to_file",
        "hooks": [
          {
            "type": "command",
            "command": "p=\"$HOME/.gemini/antigravity-cli/plugins/agent-gate\"; python3 \"$p/hooks/antigravity_adapter.py\" --event posttooluse -- python3 \"$p/hooks/readiness_gate_hook.py\" --mode bind"
          }
        ]
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "p=\"$HOME/.gemini/antigravity-cli/plugins/agent-gate\"; python3 \"$p/hooks/antigravity_adapter.py\" --event stop -- python3 \"$p/hooks/skill_invocation_verifier.py\""
      }
    ]
  }
}
