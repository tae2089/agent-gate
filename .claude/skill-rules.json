{
  "rules": [
    {
      "id": "code-edits-need-guardrails",
      "when": {
        "tool": "Write|Edit",
        "input_pattern": "\\.(go|py|ts|tsx|java|kt)\""
      },
      "require": { "skill": "coding-quality-guardrails" },
      "message": "code was written or edited this turn without the quality gate"
    },
    {
      "id": "artifact-scoring-needs-artifact-judge",
      "when": {
        "prompt_pattern": "(?i)(산출물 (평가|채점|점수)|(핸드오프|handoff|브리핑|brief).{0,12}(평가|채점|점수 매겨)|artifact (quality|judge|score)|모호한지 (평가|체크|봐))"
      },
      "require": { "skill": "artifact-judge" },
      "message": "artifact quality scoring must run through the two-tier judge, not ad-hoc opinion"
    },
    {
      "id": "debugging-needs-diagnosing-bugs",
      "when": {
        "prompt_pattern": "(?i)(디버깅|버그 ?(잡|고쳐|수정)|flaky|regression|root ?cause)"
      },
      "require": { "skill": "diagnosing-bugs" }
    },
    {
      "id": "skill-md-edits-need-writing-great-skills",
      "when": {
        "tool": "Write|Edit",
        "input_pattern": "SKILL\\.md"
      },
      "require": { "skill": "writing-great-skills" },
      "message": "SKILL.md was written or edited without the skill-authoring discipline"
    },
    {
      "id": "flow-requests-need-flow-design",
      "when": {
        "prompt_pattern": "(?i)(의사 ?코드|pseudo-?code|다이어그램|diagram|mermaid|플로우 ?차트|flow ?chart|시퀀스 (다이어그램|그려))"
      },
      "require": { "skill": "flow-design" }
    },
    {
      "id": "implementation-edits-need-flow-design",
      "when": {
        "tool": "Write|Edit",
        "input_pattern": "implementation\\.md\""
      },
      "require": { "skill": "flow-design" },
      "message": "Full-tier implementation design requires numbered pseudocode and a control-flow Mermaid diagram"
    },
    {
      "id": "dispatch-packet-needs-execute-dispatch-unit",
      "when": {
        "prompt_pattern": "(unit_id|allowed_scope|return_contract|acceptance_criteria)"
      },
      "require": { "skill": "execute-dispatch-unit" }
    },
    {
      "id": "multi-agent-needs-decompose-and-dispatch",
      "when": {
        "prompt_pattern": "(?i)(멀티 ?에이전트|multi-?agent|병렬로 (나눠|분배|작업시)|에이전트 (여러|나눠)|fan ?out)"
      },
      "require": { "skill": "decompose-and-dispatch" }
    },
    {
      "id": "review-prep-needs-ready-code-review",
      "when": {
        "prompt_pattern": "(?i)(리뷰 ?(준비|컨텍스트|브리핑|요청)|review (brief|context|prep)|reviewer (instructions?|prompts?)|리뷰어 (지침|프롬프트)|severity (rubric|calibration))"
      },
      "require": { "skill": "ready-code-review" },
      "message": "review preparation must go through ready-code-review; do not use it to perform the review itself"
    }
  ]
}
