{
  "agent-gate": {
    "PreToolUse": [
      {
        "matcher": "write|edit|apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "r=$(git rev-parse --show-toplevel); python3 \"$r/hooks/antigravity_adapter.py\" --event pretooluse -- python3 \"$r/hooks/readiness_gate_hook.py\" --mode pre"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "write|edit|apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "r=$(git rev-parse --show-toplevel); python3 \"$r/hooks/antigravity_adapter.py\" --event posttooluse -- python3 \"$r/hooks/readiness_gate_hook.py\" --mode bind"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "r=$(git rev-parse --show-toplevel); python3 \"$r/hooks/antigravity_adapter.py\" --event stop -- python3 \"$r/hooks/skill_invocation_verifier.py\" --rules \"$r/.claude/skill-rules.json\""
          },
          {
            "type": "command",
            "command": "r=$(git rev-parse --show-toplevel); python3 \"$r/hooks/antigravity_adapter.py\" --event stop -- python3 \"$r/hooks/context_watermark.py\""
          }
        ]
      }
    ]
  }
}
