{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/hooks/handoff_reinject.py\""
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "manual|auto",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/hooks/context_watermark.py\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit|apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/hooks/readiness_gate_hook.py\" --mode pre"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/hooks/readiness_gate_hook.py\" --mode bind"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "r=$(git rev-parse --show-toplevel); python3 \"$r/hooks/skill_invocation_verifier.py\" --rules \"$r/.claude/skill-rules.json\""
          },
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/hooks/context_watermark.py\""
          },
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/hooks/scenario_gate_hook.py\""
          }
        ]
      }
    ]
  }
}
